{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "doctor", "pharmacy", "physio", "hospital", "ambulance", "lab"] }
      },
      "required": ["uid", "email"]
    },
    "Medicine": {
      "title": "Medicine",
      "description": "Medicine available in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor profile for consultations",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "fee": { "type": "number" },
        "availability": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "specialty", "fee"]
    },
    "LabTest": {
      "title": "LabTest",
      "description": "Diagnostic lab test details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Digital prescription for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "medicines": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["userId", "doctorName", "date"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Appointment for doctor or lab test",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["doctor", "lab"] },
        "targetId": { "type": "string" },
        "targetName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] }
      },
      "required": ["userId", "type", "targetId", "date"]
    },
    "CallSession": {
      "title": "CallSession",
      "description": "Information about a video call session",
      "type": "object",
      "properties": {
        "channelName": { "type": "string" },
        "token": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientId": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "active", "ended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["channelName", "doctorId", "patientId", "status"]
    },
    "GlobalPrescription": {
      "title": "GlobalPrescription",
      "description": "Prescription stored in global collection",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "specialty": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "items": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string" }
      },
      "required": ["userId", "doctorId", "date", "items"]
    },
    "ServiceRequest": {
      "title": "ServiceRequest",
      "description": "Request for specialized services like Ambulance or Physio",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["ambulance", "physio", "hospital", "lab"] },
        "details": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "assigned", "completed", "cancelled"] },
        "assignedProviderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceType", "status", "createdAt"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "User or Provider balance information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "balance": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "balance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Payment and revenue split transaction record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "providerId": { "type": "string" },
        "amount": { "type": "number" },
        "providerShare": { "type": "number" },
        "shustoShare": { "type": "number" },
        "type": { "type": "string", "enum": ["payment", "add_money", "withdrawal"] },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "sslTransactionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/medicines/{medicineId}": {
      "schema": "Medicine",
      "description": "Catalog of medicines"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "List of doctors"
    },
    "/labTests/{testId}": {
      "schema": "LabTest",
      "description": "List of lab tests"
    },
    "/users/{userId}/prescriptions/{prescriptionId}": {
      "schema": "Prescription",
      "description": "User's digital prescriptions"
    },
    "/users/{userId}/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "User's scheduled appointments"
    },
    "/callSessions/{sessionId}": {
      "schema": "CallSession",
      "description": "Active and past video call sessions"
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "GlobalPrescription",
      "description": "All prescriptions in the system"
    },
    "/serviceRequests/{requestId}": {
      "schema": "ServiceRequest",
      "description": "Requests for ambulance, physio, etc."
    },
    "/wallets/{walletId}": {
      "schema": "Wallet",
      "description": "User and provider wallet balances"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Payment and split records"
    }
  }
}
